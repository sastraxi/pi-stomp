@prefix ingen:    <http://drobilla.net/ns/ingen#> .
@prefix lv2:      <http://lv2plug.in/ns/lv2core#> .
@prefix modpedal: <http://moddevices.com/ns/modpedal#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .

# Marker-only pedalboard. pi-Stomp detects nam_capture: true in config.yml and
# mounts NamCapturePanel instead of the normal plugin grid. The audio graph
# here is intentionally empty; the capture engine manages JACK routing directly.

<http://pistomp.local/pedalboards/NAMCapture>
    a lv2:Plugin ,
        modpedal:Pedalboard ;
    rdfs:label "NAM Capture" ;
    ingen:enabled 1 .
